{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
      }
    }
  },
  "Database": {
    "ConnectionString": "",
    "Provider": ""
  },
  "Messaging": {
    "Outbox": {
      "ProcessFrequencyInSec": 5,
      "ProcessBatchSize": 100,
      "ClaimTimeoutInMin": 5,
      "ArchiveFrequencyInSec": 120,
      "ArchiveBatchSize": 100,
      "ArchiveTimeoutInMin": 1440
    },
    "Inbox": {
      "ArchiveFrequencyInSec": 120,
      "ArchiveBatchSize": 100,
      "ArchiveTimeoutInMin": 1440
    }
  },
  "Cookie": {
    "Name": null,
    "UseStrict": false,
    "Domain": "",
    "ExpiryInDays": 7
  },
  "Jwt": {
    "Secret": "",
    "ExpiryInMinutes": 60,
    "Issuer": "pulse",
    "Audience": "pulse"
  },
  "DataProtection": {
    "Mode": "Default"
  }
}
