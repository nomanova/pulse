{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
      }
    }
  },
  "Database": {
    "ConnectionString": "",
    "Provider": ""
  },
  "Outbox": {
    "FrequencyInSec": 5,
    "BatchSize": 100,
    "ClaimTimeoutInMin": 5,
    "Queue": "InMemory"
  },
  "Cookie": {
    "Name": null,
    "UseStrict": false,
    "Domain": "",
    "ExpiryInDays": 7
  },
  "Jwt": {
    "Secret": "",
    "ExpiryInMinutes": 60,
    "Issuer": "pulse",
    "Audience": "pulse"
  },
  "DataProtection": {
    "Mode": "Default"
  }
}
